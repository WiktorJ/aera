                <geom name="arc_l1_back_s2" type="capsule" fromto="0 0.0262 -0.074 0 0.0368 -0.101" size="0.005" material="cable_mat" rgba="0.05 0.05 0.05 1" mass="0" contype="0" conaffinity="0" group="2"/>
                <geom name="arc_l1_back_s3" type="capsule" fromto="0 0.0368 -0.101 0 0.0474 -0.128" size="0.005" material="cable_mat" rgba="0.05 0.05 0.05 1" mass="0" contype="0" conaffinity="0" group="2"/>
                <geom name="arc_l1_back_s4" type="capsule" fromto="0 0.0474 -0.128 0 0.058 -0.155" size="0.005" material="cable_mat" rgba="0.05 0.05 0.05 1" mass="0" contype="0" conaffinity="0" group="2"/>
                <body name="link_2" pos="0 0.064146 -0.16608" quat="0.353551 0.612373 -0.353555 -0.612373">
                    <inertial pos="0.064818 -0.11189 -0.038671" quat="0.637507 0.725997 0.196395 0.167158"
                              mass="0.57738"
                              diaginertia="0.00602866 0.00569905 0.000699994"/>
                    <joint name="joint_2" pos="0 0 0" axis="0 0 -1" range="-0.733038 1.5708" class="size4"/>
                    <geom type="mesh" mesh="link_2" material="link_2_mat"/>
                    <!-- Wiring-harness tubes (visual only; geometry DR in
                         _sample_arm_cables toggles/recolors/jitters these per
                         episode). The DR goal is silhouette variety, not a
                         faithful copy of the real harness, so placements are
