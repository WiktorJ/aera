<mujoco model="ar4_mk3">
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.002" integrator="implicitfast">
        <flag contact="enable" multiccd="enable"/>
    </option>
    <!-- <statistic meansize="0.116999" extent="0.779996" center="0.0273132 -0.0950417 0.259419"/> -->
    <asset>
        <material name="white" rgba="1 1 1 1"/>
        <material name="red" rgba="1 0 0 1"/>
        <material name="blue" rgba="0 0 1 1"/>
        <material name="black" rgba="0 0 0 1"/>
        <material name="gray" rgba="0.753 0.753 0.753 1"/>
        <material name="transparent" rgba="0 0 0 0"/>
        <!-- Wiring-harness tubes. Slight sheen so black tubing/heat-shrink reads
             as rubber/plastic rather than flat matte. geom_rgba (set per segment
             at runtime) overrides the albedo; this material only supplies the
             finish. -->
        <material name="cable_mat" specular="0.4" shininess="0.3" reflectance="0.02" rgba="0.05 0.05 0.05 1"/>
        <!-- texrepeat tiles the texture across each link's bbox so 1K source
             textures stay sharp on ~10-20 cm parts. texuniform stays false
             (default) so the projection is bbox-relative and the texture
             travels with the link instead of swimming past it during motion. -->
        <material name="base_link_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="link_1_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="link_2_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="link_3_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="link_4_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="link_5_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="link_6_mat" texrepeat="3 3" rgba="1 1 1 1"/>
        <material name="gripper_base_link_mat" texrepeat="2 2" rgba="1 1 1 1"/>
        <material name="gripper_jaw1_mat" texrepeat="2 2" rgba="0.149 0.149 0.149 1"/>
        <material name="gripper_jaw2_mat" texrepeat="2 2" rgba="0.149 0.149 0.149 1"/>
        <material name="block_mat" specular="0" shininess="0.5" reflectance="0" rgba="0.2 0.2 0.2 1"></material>
        <material name="target_mat" specular="0" shininess="0.5" reflectance="0" rgba="1 0 0 0.5"/>
        <material name="distractor1_mat" specular="0" shininess="0.5" reflectance="0" rgba="0 1 0 0.5"/>
        <material name="distractor2_mat" specular="0" shininess="0.5" reflectance="0" rgba="0 0 1 0.5"/>
        <material name="object_mat" specular="0" shininess="0.5" reflectance="0" rgba="1 1 0 1"/>
        <material name="object_distractor1_mat" specular="0" shininess="0.5" reflectance="0" rgba="0 1 0 1"/>
        <material name="object_distractor2_mat" specular="0" shininess="0.5" reflectance="0" rgba="0 0 1 1"/>

        <mesh name="base_link" file="assets/base_link.STL"/>
        <mesh name="link_1" file="assets/link_1.STL"/>
        <mesh name="link_2" file="assets/link_2.STL"/>
        <mesh name="link_3" file="assets/link_3.STL"/>
        <mesh name="link_4" file="assets/link_4.STL"/>
        <mesh name="link_5" file="assets/link_5.STL"/>
        <mesh name="link_6" file="assets/link_6.STL"/>
        <mesh name="gripper_base_link" file="assets/gripper_base_link.stl"/>
        <mesh name="gripper_jaw1_link" file="assets/gripper_jaw1_link.stl"/>
        <mesh name="gripper_jaw2_link" file="assets/gripper_jaw2_link.stl"/>
        <!-- Pickable-block visual presets (visual only; collision stays the box
             geom). Each preset = one of the 6 edge OBJs (generated by
             scripts/generate_pla_block_mesh.py, authored at unit half-extent,
             carrying UVs for the layer texture) at one of 5 scales. The DR pass
             shows one preset geom per block per episode and scales the collision
             box to match. Mesh names / scales must match PLA_BLOCK_PRESETS in
             ar4_mk3_config.py. -->
        <mesh name="pla_block_p0" file="assets/pla_block_chamfer_s.obj" scale="0.0095 0.0095 0.0095"/>
        <mesh name="pla_block_p1" file="assets/pla_block_chamfer_m.obj" scale="0.011 0.011 0.011"/>
        <mesh name="pla_block_p2" file="assets/pla_block_chamfer_l.obj" scale="0.012 0.012 0.012"/>
        <mesh name="pla_block_p3" file="assets/pla_block_fillet_s.obj" scale="0.0135 0.0135 0.0135"/>
        <mesh name="pla_block_p4" file="assets/pla_block_fillet_m.obj" scale="0.015 0.015 0.015"/>
        <mesh name="pla_block_p5" file="assets/pla_block_fillet_l.obj" scale="0.0095 0.0095 0.0095"/>
        <mesh name="pla_block_p6" file="assets/pla_block_chamfer_s.obj" scale="0.011 0.011 0.011"/>
        <mesh name="pla_block_p7" file="assets/pla_block_chamfer_m.obj" scale="0.012 0.012 0.012"/>
        <mesh name="pla_block_p8" file="assets/pla_block_chamfer_l.obj" scale="0.0135 0.0135 0.0135"/>
        <mesh name="pla_block_p9" file="assets/pla_block_fillet_s.obj" scale="0.015 0.015 0.015"/>
        <mesh name="pla_block_p10" file="assets/pla_block_fillet_m.obj" scale="0.0095 0.0095 0.0095"/>
        <mesh name="pla_block_p11" file="assets/pla_block_fillet_l.obj" scale="0.011 0.011 0.011"/>
        <mesh name="pla_block_p12" file="assets/pla_block_chamfer_s.obj" scale="0.012 0.012 0.012"/>
        <mesh name="pla_block_p13" file="assets/pla_block_chamfer_m.obj" scale="0.0135 0.0135 0.0135"/>
        <mesh name="pla_block_p14" file="assets/pla_block_chamfer_l.obj" scale="0.015 0.015 0.015"/>
    </asset>

    <default>
        <default class="ar4_mk3">
            <material specular="0.5" shininess="0.25"/>
            <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
            <position ctrlrange="-6.2831 6.2831"/>
            <general biastype="affine" ctrlrange="-6.2831 6.2831" gainprm="1000" biasprm="0 -1000 -100"/>
            <default class="size5">
                <joint damping="0"/>
                <general forcerange="-330 330" gainprm="0"/>
            </default>
            <default class="size4">
                <joint damping="20"/>
                <general forcerange="-330 330" gainprm="0"/>
            </default>
            <default class="size3">
                <joint damping="10"/>
                <general forcerange="-150 150" gainprm="0"/>
            </default>
            <default class="size2">
                <joint damping="4"/>
                <general forcerange="-56 56" gainprm="0"/>
            </default>
            <default class="size1">
                <joint damping="10"/>
                <general forcerange="-56 56" gainprm="50" biasprm="0 -50 -5" ctrlrange="-0.014 0"/>
            </default>
            <default class="visual">
                <geom type="mesh" contype="0" conaffinity="0" group="2"/>
            </default>
            <default class="collision">
                <geom type="capsule" group="3"/>
                <default class="eef_collision">
                    <geom type="cylinder"/>
                </default>
            </default>
            <default class="position">
              <position kp="20000" kv="250" forcerange="-1000 1000"/>
              <default class="position3">
                <position kp="5000" kv="60" forcerange="-200 200"/>
              </default>
            </default>
        </default>
    </default>

    <worldbody>
        <body name="target_visual_body" pos="0.2 0.2 0">
            <geom name="target_visual" type="box" size="0.025 0.025 0.001" pos="0 0 0.0" material="target_mat" contype="0" conaffinity="0" group="2"/>
        </body>
        <body name="target_distractor1_visual_body" pos="0.3 0.3 0">
            <geom name="distractor1_visual" type="box" size="0.025 0.025 0.001" pos="0 0 0.0" material="distractor1_mat" contype="0" conaffinity="0" group="2"/>
        </body>
        <body name="target_distractor2_visual_body" pos="0.4 0.4 0">
            <geom name="distractor2_visual" type="box" size="0.025 0.025 0.001" pos="0 0 0.0" material="distractor2_mat" contype="0" conaffinity="0" group="2"/>
        </body>
        <site name="target0" pos="0.2 0.2 0" size="0.005" rgba="0 0 0 0" type="sphere"/>
        <!-- Each pickable block: an invisible collision box (unchanged grasp
             physics) plus a chamfered visual mesh carrying the PLA material. The
             box keeps the geom name so dynamics DR (friction/mass) still targets
             it; the mesh geom has mass="0" so body inertia is unchanged. -->
        <body name="object0" pos="-0.15 -0.3 0.2">
          <joint name="object0:joint" type="free" damping="0"></joint>
          <geom size="0.012 0.012 0.012" type="box" condim="3" name="object0" rgba="0 0 0 0" mass="0.1"
            friction="2.0 0.5 0.1" contype="1" conaffinity="1" solref="0.004 1" solimp="0.95 0.99 0.001 0.5 2"/>
          <geom name="object0_visual_p0" type="mesh" mesh="pla_block_p0" material="object_mat" mass="0" contype="0" conaffinity="0" group="2"/>
          <geom name="object0_visual_p1" type="mesh" mesh="pla_block_p1" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p2" type="mesh" mesh="pla_block_p2" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p3" type="mesh" mesh="pla_block_p3" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p4" type="mesh" mesh="pla_block_p4" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p5" type="mesh" mesh="pla_block_p5" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p6" type="mesh" mesh="pla_block_p6" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p7" type="mesh" mesh="pla_block_p7" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p8" type="mesh" mesh="pla_block_p8" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p9" type="mesh" mesh="pla_block_p9" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p10" type="mesh" mesh="pla_block_p10" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p11" type="mesh" mesh="pla_block_p11" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p12" type="mesh" mesh="pla_block_p12" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p13" type="mesh" mesh="pla_block_p13" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object0_visual_p14" type="mesh" mesh="pla_block_p14" material="object_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <site name="object0" pos="0 0 0" size="0.002 0.002 0.002" rgba="1 0 0 1" type="sphere"></site>
        </body>
        <body name="object_distractor1" pos="-0.15 -0.3 0.2">
          <joint name="object_distractor1:joint" type="free" damping="0"></joint>
          <geom size="0.012 0.012 0.012" type="box" condim="3" name="object_distractor1" rgba="0 0 0 0" mass="0.1"
