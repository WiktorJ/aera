          <geom name="object_distractor2_visual_p0" type="mesh" mesh="pla_block_p0" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2"/>
          <geom name="object_distractor2_visual_p1" type="mesh" mesh="pla_block_p1" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor2_visual_p2" type="mesh" mesh="pla_block_p2" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor2_visual_p3" type="mesh" mesh="pla_block_p3" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor2_visual_p4" type="mesh" mesh="pla_block_p4" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
