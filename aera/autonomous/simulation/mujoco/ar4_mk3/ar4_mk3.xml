          <geom name="object_distractor2_visual_p7" type="mesh" mesh="pla_block_p7" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor2_visual_p8" type="mesh" mesh="pla_block_p8" material="object_distractor2_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
