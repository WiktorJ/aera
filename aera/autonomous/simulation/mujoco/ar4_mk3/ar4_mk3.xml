                         case. arc_l2_back: link 2↔3 run bowing off the back. -->
                    <geom name="arc_l2_back_s0" type="capsule" fromto="0.010 -0.020 0 0.036 -0.065 0" size="0.005" material="cable_mat" rgba="0.05 0.05 0.05 1" mass="0" contype="0" conaffinity="0" group="2"/>
