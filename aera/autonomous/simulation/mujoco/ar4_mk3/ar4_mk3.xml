                    <geom name="arc_l2_back_s2" type="capsule" fromto="0.062 -0.110 0 0.088 -0.155 0" size="0.005" material="cable_mat" rgba="0.05 0.05 0.05 1" mass="0" contype="0" conaffinity="0" group="2"/>
