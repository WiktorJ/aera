          <geom name="object_distractor1_visual_p2" type="mesh" mesh="pla_block_p2" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p3" type="mesh" mesh="pla_block_p3" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p4" type="mesh" mesh="pla_block_p4" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p5" type="mesh" mesh="pla_block_p5" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p6" type="mesh" mesh="pla_block_p6" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p7" type="mesh" mesh="pla_block_p7" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p8" type="mesh" mesh="pla_block_p8" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p9" type="mesh" mesh="pla_block_p9" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p10" type="mesh" mesh="pla_block_p10" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p11" type="mesh" mesh="pla_block_p11" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p12" type="mesh" mesh="pla_block_p12" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p13" type="mesh" mesh="pla_block_p13" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <geom name="object_distractor1_visual_p14" type="mesh" mesh="pla_block_p14" material="object_distractor1_mat" mass="0" contype="0" conaffinity="0" group="2" rgba="1 1 1 0"/>
          <site name="object_distractor1" pos="0 0 0" size="0.002 0.002 0.002" rgba="0 1 0 1" type="sphere"></site>
        </body>
        <body name="object_distractor2" pos="-0.15 -0.3 0.2">
          <joint name="object_distractor2:joint" type="free" damping="0"></joint>
