    <texture type="2d" name="fabric083" file="../../textures/fabric083.png"/>
    <texture type="2d" name="marble012" file="../../textures/marble012.png"/>
    <texture type="2d" name="marble016" file="../../textures/marble016.png"/>
    <texture type="2d" name="marble021" file="../../textures/marble021.png"/>
    <texture type="2d" name="plastic006" file="../../textures/plastic006.png"/>
    <texture type="2d" name="plastic010" file="../../textures/plastic010.png"/>
    <texture type="2d" name="plastic012a" file="../../textures/plastic012a.png"/>
    <texture type="2d" name="plastic013a" file="../../textures/plastic013a.png"/>
    <texture type="2d" name="plastic015a" file="../../textures/plastic015a.png"/>
    <!-- Procedural FDM layer-line textures for the task objects / target plates,
         generated by scripts/generate_pla_textures.py. Grayscale so the runtime
         rgba tint-multiply recovers any filament color. The object/target
         materials bind these at runtime (mat_texid), so they only need to be
         declared here, not pre-bound to a material. -->
    <texture type="2d" name="pla_lines_fine" file="../../textures/pla_lines_fine.png"/>
    <texture type="2d" name="pla_lines_medium" file="../../textures/pla_lines_medium.png"/>
    <texture type="2d" name="pla_lines_coarse" file="../../textures/pla_lines_coarse.png"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0"/>
    <!-- texuniform=true so the same tile density (~1 repeat / meter) applies
         across all walls and the ceiling regardless of geom size. -->
    <material name="wallmaterial" texuniform="true" texrepeat="1 1" rgba="0.5 0.5 0.5 1"/>
    <material name="tablemat" texuniform="true" texrepeat="2 2" rgba="0.6 0.4 0.25 1"/>
    <!-- Background shelf — fixed wood look so the unit reads as furniture and
         doesn't drift visually with each episode's randomized table/wall mats. -->
    <material name="shelfmat" texture="wood049" texuniform="true" texrepeat="2 2" reflectance="0"/>
    <!-- Wall-art textures — CC0 paintings downloaded by
         scripts/download_paintings.py. Runtime picks one of these per episode
         and assigns it to wallartmat by writing mat_texid. Adding/removing a
         file here requires re-listing it; the runtime only sees textures
         declared in this XML. -->
    <texture type="2d" name="painting_11" file="../../props/_paintings/painting_11.png"/>
    <texture type="2d" name="painting_9" file="../../props/_paintings/painting_9.png"/>
    <texture type="2d" name="painting_874" file="../../props/_paintings/painting_874.png"/>
    <texture type="2d" name="painting_14655" file="../../props/_paintings/painting_14655.png"/>
    <texture type="2d" name="painting_30368" file="../../props/_paintings/painting_30368.png"/>
    <texture type="2d" name="painting_44065" file="../../props/_paintings/painting_44065.png"/>
    <texture type="2d" name="painting_61158" file="../../props/_paintings/painting_61158.png"/>
    <texture type="2d" name="painting_64754" file="../../props/_paintings/painting_64754.png"/>
    <texture type="2d" name="painting_65821" file="../../props/_paintings/painting_65821.png"/>
    <texture type="2d" name="painting_87088" file="../../props/_paintings/painting_87088.png"/>
    <texture type="2d" name="painting_90048" file="../../props/_paintings/painting_90048.png"/>
    <texture type="2d" name="painting_97933" file="../../props/_paintings/painting_97933.png"/>
    <texture type="2d" name="painting_111377" file="../../props/_paintings/painting_111377.png"/>
    <texture type="2d" name="painting_146701" file="../../props/_paintings/painting_146701.png"/>
    <texture type="2d" name="painting_181777" file="../../props/_paintings/painting_181777.png"/>
    <!-- Default material for the wall-art slab. Needs a default texture
         binding (`texture="painting_9"`) — without it MuJoCo compiles the
         material as untextured and runtime mat_texid writes have no visual
         effect. The actual texture is swapped per-episode by the runtime.
         rgba alpha=0 hides the slab when the sampler picks "inactive".
         Boards live on a separate untextured material so we can switch the
         geom between the two via geom_matid. -->
    <material name="wallartmat" texture="painting_9" texuniform="false" texrepeat="1 1" rgba="1 1 1 0"/>
    <material name="wallboardmat" texuniform="false" rgba="1 1 1 0"/>
  </asset>

  <worldbody>
    <light name="scene_light" pos="0 0 1.5" dir="0 0 -1" directional="true" diffuse="0.2 0.2 0.2"/>
    <light name="top" pos="0 0 2" mode="trackcom" diffuse="0 0 0"/>
    <!-- Room floor: the actual ground, sits one table-height below the work
         surface. Non-colliding — objects rest on `floor` (the table top). -->
    <geom name="room_floor" size="0 0 0.05" type="plane" material="groundplane" pos="0 0 -0.75" contype="0" conaffinity="0"/>
    <!-- Visual work-surface slab. Kept named `floor` so existing mj_name2id
         lookups still resolve. Visual-only — collision is handled by
         `table_collision` below, which extends much deeper to prevent objects
         from tunneling through a thin top during high-impact contact events
         (e.g. gripper releasing a held object). -->
    <geom name="floor" type="box" size="0.6 0.55 0.01" pos="0 -0.2 -0.01" material="tablemat" contype="0" conaffinity="0"/>
    <!-- Invisible deep collision volume. Matches table-top xy footprint but
         spans the full pedestal height so the contact MTV is always toward
         the +z face regardless of how deep an object penetrates. Default
         geometry is overwritten per-episode by domain randomization. -->
    <geom name="table_collision" type="box" size="0.6 0.55 0.375" pos="0 -0.2 -0.375" rgba="0 0 0 0" group="3"/>
    <!-- Visual pedestal under the table top. Default geometry is overwritten
         per-episode when domain randomization is active. -->
    <geom name="table_pedestal" type="box" size="0.5 0.45 0.365" pos="0 -0.2 -0.385" material="tablemat" contype="0" conaffinity="0"/>
    <!-- Walls: span from room floor (z=-0.75) to ceiling (z=1.75). -->
    <geom name="wall_y_pos" type="box" size="3 0.01 1.25" pos="0 2 0.5" material="wallmaterial" contype="0" conaffinity="0"/>
    <geom name="wall_y_neg" type="box" size="3 0.01 1.25" pos="0 -2 0.5" material="wallmaterial" contype="0" conaffinity="0"/>
    <geom name="wall_x_pos" type="box" size="0.01 3 1.25" pos="2 0 0.5" material="wallmaterial" contype="0" conaffinity="0"/>
    <geom name="wall_x_neg" type="box" size="0.01 3 1.25" pos="-2 0 0.5" material="wallmaterial" contype="0" conaffinity="0"/>
    <!-- Ceiling -->
    <geom name="ceiling" type="box" size="3 3 0.01" pos="0 0 1.75" material="wallmaterial" contype="0" conaffinity="0"/>
    <!-- Background shelf unit along the y=-2 wall, shifted toward the -x
         corner. Fixed geometry, sized to fit the resolved render camera's
         view cone — that camera sits ~(+0.70, +0.42, +0.60) and looks back
         toward (-x, -y, -z); its principal ray hits the y=-2 wall at the
         (-x, -y) corner. The shelf is centered there so it sits squarely in
         frame. Shelf depth (in +y) is 0.13m; length (in x) is 1.5m; levels
         are at z ∈ {-0.40, 0.10, 0.60}. Top-of-slab z = level_z + 0.015.
         The sampler in domain_rand_config_generator.py uses SHELF_X_RANGE /
         SHELF_Y_RANGE / SHELF_LEVEL_TOPS to place props on these surfaces;
         if you move/resize the unit here, update those constants to match.
         Non-colliding — props pose on top without contact physics. -->
    <geom name="shelf_side_neg" type="box" size="0.02 0.13 0.55" pos="-1.70 -1.85 0.10" material="shelfmat" contype="0" conaffinity="0"/>
    <geom name="shelf_side_pos" type="box" size="0.02 0.13 0.55" pos="-0.70 -1.85 0.10" material="shelfmat" contype="0" conaffinity="0"/>
    <geom name="shelf_level_0" type="box" size="0.50 0.13 0.015" pos="-1.20 -1.85 -0.40" material="shelfmat" contype="0" conaffinity="0"/>
    <geom name="shelf_level_1" type="box" size="0.50 0.13 0.015" pos="-1.20 -1.85 0.10" material="shelfmat" contype="0" conaffinity="0"/>
    <geom name="shelf_level_2" type="box" size="0.50 0.13 0.015" pos="-1.20 -1.85 0.60" material="shelfmat" contype="0" conaffinity="0"/>
    <!-- Wall art / board slot on the otherwise-empty wall_x_neg side. Uses
         type="plane" — not "box" — because a thin box's bbox-based UV mapping
         collapses on the thinnest dimension and the texture renders as a
         degenerate one-pixel-wide strip (i.e. a flat average color). Planes
         get proper UV across their face. The quaternion (0.5 0.5 0.5 0.5)
         is a cyclic rotation x→y→z→x, mapping local +X → world +Y,
         local +Y → world +Z, local +Z (the plane's normal) → world +X.
         Result: the painting's horizontal axis lies along world Y, vertical
         along world Z, and the face points into the room. After this rotation
         size[0] = world Y half-extent, size[1] = world Z half-extent,
         size[2] is the infinite-plane grid spacing (ignored once a texture
         is bound). The plane sits 5mm in front of the wall (wall inside face
         is at x=-1.99) to avoid z-fighting. Runtime overrides geom_pos,
         geom_size, geom_rgba, geom_matid (paintings vs boards), and
         mat_texid on wallartmat. -->
    <geom name="wall_art" type="plane" size="0.40 0.30 1" pos="-1.985 0 0.6" quat="0.5 0.5 0.5 0.5" material="wallartmat" contype="0" conaffinity="0"/>
<!--    <geom type="cylinder" size=".06 .06" pos="0 0 .06" rgba="1 1 1 1"/>-->
  </worldbody>
</mujoco>
